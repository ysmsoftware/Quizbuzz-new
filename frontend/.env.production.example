# QuizBuzz - Production Environment Template
# Copy this file to .env.production and populate the values.

# ─── WebSocket & APIs ─────────────────────────────────────────
NEXT_PUBLIC_WS_URL=https://api.ysmquizbuzz.com
NEXT_PUBLIC_SOCKET_URL=https://api.ysmquizbuzz.com
NEXT_PUBLIC_APP_URL=https://ysmquizbuzz.com
NEXT_PUBLIC_API_URL=https://api.ysmquizbuzz.com/api/v1

# ─── Sentry Monitoring ────────────────────────────────────────
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_ORG=ysm-infosolution
SENTRY_PROJECT=quizbuzz-frontend

# ─── PostHog Analytics ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── PWA Config ───────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_PWA=true
