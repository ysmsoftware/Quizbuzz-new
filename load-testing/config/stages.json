{
  "domain": "REPLACE_WITH_ALB_DNS_OR_DOMAIN",
  "protocol": {
    "http": "http",
    "ws": "ws"
  },
  "notes": "During load testing, point this at the ALB's own DNS name directly (terraform output alb_dns_name), NOT at the manually-switched host.co.in A record — this avoids any DNS TTL/propagation lag from polluting your load test results. Switch to the real domain only for the final confirmation run.",

  "defaults": {
    "thinkTimeMinSec": 10,
    "thinkTimeMaxSec": 30,
    "reconnectFraction": 0.05,
    "reconnectDelayMinSec": 5,
    "reconnectDelayMaxSec": 15,
    "answerLatencyP95ThresholdMs": 500,
    "wsConnectSuccessRateThreshold": 0.99,
    "questionsPerQuiz": 20,
    "rampUsersPerSecond": 50
  },

  "stages": [
    {
      "id": 0,
      "label": "smoke",
      "users": 50,
      "rampUpSeconds": 5,
      "holdMinutes": 5,
      "rampDownSeconds": 30,
      "expectedInstancesMin": 2,
      "expectedInstancesMax": 2
    },
    {
      "id": 1,
      "label": "baseline-1k",
      "users": 1000,
      "rampUpSeconds": 20,
      "holdMinutes": 10,
      "rampDownSeconds": 60,
      "expectedInstancesMin": 2,
      "expectedInstancesMax": 3
    },
    {
      "id": 2,
      "label": "scale-out-2k",
      "users": 2000,
      "rampUpSeconds": 40,
      "holdMinutes": 10,
      "rampDownSeconds": 60,
      "expectedInstancesMin": 3,
      "expectedInstancesMax": 4
    },
    {
      "id": 3,
      "label": "midscale-4k",
      "users": 4000,
      "rampUpSeconds": 80,
      "holdMinutes": 15,
      "rampDownSeconds": 90,
      "expectedInstancesMin": 4,
      "expectedInstancesMax": 5
    },
    {
      "id": 4,
      "label": "reference-5k",
      "users": 5000,
      "rampUpSeconds": 100,
      "holdMinutes": 15,
      "rampDownSeconds": 90,
      "expectedInstancesMin": 5,
      "expectedInstancesMax": 5
    },
    {
      "id": 5,
      "label": "above-reference-6k",
      "users": 6000,
      "rampUpSeconds": 120,
      "holdMinutes": 15,
      "rampDownSeconds": 90,
      "expectedInstancesMin": 6,
      "expectedInstancesMax": 6
    },
    {
      "id": 6,
      "label": "hard-cap-10k",
      "users": 10000,
      "rampUpSeconds": 200,
      "holdMinutes": 20,
      "rampDownSeconds": 120,
      "expectedInstancesMin": 10,
      "expectedInstancesMax": 10
    }
  ]
}
