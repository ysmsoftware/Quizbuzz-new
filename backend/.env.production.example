PROCTORING_STRICT_MODE=true

########################################
# HEALTH & MONITORING

HEALTHCHECK_ENABLED=true
METRICS_ENABLED=true

########################################
# LOGGING

LOG_LEVEL=info
LOG_FORMAT=json

########################################
# TESTING / DEBUG FLAGS

ENABLE_DEBUG_LOGS=false
MOCK_PAYMENT=false

########################################
# TIMEOUTS
API_TIMEOUT=10000
DB_TIMEOUT=20000
REDIS_TIMEOUT=3000

########################################
# CONTEST CONTROL

